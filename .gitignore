# Unity standard
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/
[Aa]ssets/[Aa]ssetStoreTools*
[Aa]ssets/[Aa]ssetStoreTools*.meta

# Asset .meta files MUST be tracked alongside their assets (otherwise GUIDs
# diverge between developers and CI, breaking references). This negation
# rule is defensive: even if some pattern above accidentally matches a
# .meta inside Assets/, this line re-includes it.
!/[Aa]ssets/**/*.meta
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.idb
*.iobj
*.ipdb
*.ipch
sysinfo.txt
*.apk
*.aab
*.unitypackage
*.app
crashlytics-build.properties

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/

# Claude Code (local agent state)
.claude/

# Project specific
/Builds/
*.log
